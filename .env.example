# PrestaFacilito environment template
# No subir este archivo con valores reales. Copia a `.env` y completa los valores.

# Core APIs
GEMINI_API_KEY=""
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_KEY="tu-anon-key-o-service-role-key"

# Google Integrations (Drive & Calendar) via OAuth 2.0
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GOOGLE_DRIVE_FOLDER_ID="id-de-carpeta-para-vouchers"
GOOGLE_DRIVE_CLIENTES_FOLDER_ID="id-de-carpeta-para-documentos-de-clientes"

# Authentication & Admins
ADMIN_USER="admin"
ADMIN_PASS="tu-password-segura-admin"
PIN_SJAQUER="1234"
PIN_RJAQUE="5678"
JWT_SECRET="un-secreto-muy-seguro-y-largo"
